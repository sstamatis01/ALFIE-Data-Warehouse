# XAI integration — copy to .env before `docker compose up`.
# Defaults: localhost AutoDW + Kafka (run autodw stack first, or point to your DW).

# -----------------------------------------------------------------------------
# GitLab image (MODULE=xai under external/alfie_eu/alfie)
# -----------------------------------------------------------------------------
XAI_IMAGE=gitlab.catalink.eu:5050/external/alfie_eu/alfie/xai
XAI_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Host ports (XAI HTTP services)
# -----------------------------------------------------------------------------
UNIVERSAL_EXPLAINABILITY_PORT=5010
FLEXIBLE_INTERPRETABILITY_PORT=5001

# -----------------------------------------------------------------------------
# Data Warehouse API (where reports are uploaded)
# -----------------------------------------------------------------------------
# From host, when AutoDW publishes :8000:
API_BASE=http://host.docker.internal:8000
# From another container on the same Docker network as AutoDW api service:
# API_BASE=http://api:8000

# -----------------------------------------------------------------------------
# Kafka (trigger consumption)
# -----------------------------------------------------------------------------
# From host / other compose on same machine (AutoDW KAFKA_ADVERTISED_HOST=localhost):
KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092
# If attached to autodw-network (see README):
# KAFKA_BOOTSTRAP_SERVERS=kafka:29092

KAFKA_XAI_TRIGGER_TOPIC=xai-trigger-events
KAFKA_CONSUMER_GROUP=xai-consumer

# -----------------------------------------------------------------------------
# In-stack URLs (consumer → Flask workers; usually leave as-is)
# -----------------------------------------------------------------------------
UNIVERSAL_MODEL_EXPLAINABILITY_URL=http://universal-model-explainability:5010/explain-model
FLEXIBLE_DATA_INTERPRETABILITY_URL=http://flexible-data-interpretability:5001/analyze-data

# -----------------------------------------------------------------------------
# Reports output on host (optional bind mount)
# -----------------------------------------------------------------------------
XAI_REPORTS_HOST_DIR=./reports
