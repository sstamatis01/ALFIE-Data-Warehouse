# Copy to: <xai-repo>/.github/workflows/docker-build-push.yml
# Adjust dockerfile: if your file is not Dockerfile.xai-services

name: Build and Push Docker Images

on:
  push:
    tags:
      - 'v*.*.*'

env:
  REGISTRY: gitlab.catalink.eu:5050
  IMAGE_PREFIX: gitlab.catalink.eu:5050/external/alfie_eu/alfie/xai

jobs:
  build-push:
    name: Build and Push xai
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Log in to GitLab Container Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ vars.DOCKER_REGISTRY_USERNAME }}
          password: ${{ secrets.DOCKER_REGISTRY_PASSWORD }}

      - name: Extract version
        id: version
        run: echo "tag=${GITHUB_REF_NAME#v}" >> $GITHUB_OUTPUT

      - name: Set up QEMU
        uses: docker/setup-qemu-action@v3

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build and push xai
        uses: docker/build-push-action@v6
        with:
          context: .
          file: ./Dockerfile.xai-services
          platforms: linux/amd64,linux/arm64
          push: true
          tags: |
            ${{ env.IMAGE_PREFIX }}:${{ steps.version.outputs.tag }}
            ${{ env.IMAGE_PREFIX }}:latest
