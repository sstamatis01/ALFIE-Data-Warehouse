# AutoDW integration — copy to .env and adjust per environment.
# Values here are expected to change between dev, staging, and production.

# -----------------------------------------------------------------------------
# Container registry (pre-built AutoDW application image)
# -----------------------------------------------------------------------------
AUTODW_IMAGE=gitlab.catalink.eu:5050/external/alfie_eu/alfie/autodw
AUTODW_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Public host / reverse proxy
# -----------------------------------------------------------------------------
# DNS or IP that external clients use (Kafka advertised listener, public API URL).
PUBLIC_HOST=alfie.iti.gr
# When API is served behind a path prefix (e.g. https://alfie.iti.gr/autodw)
ROOT_PATH=/autodw

# -----------------------------------------------------------------------------
# Host port mappings (reassign on production if ports conflict)
# -----------------------------------------------------------------------------
API_PORT=8000
KAFKA_PORT=9092
KAFKA_UI_PORT=8081
MONGO_PORT=27017
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
GRAPHDB_PORT=7200

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_INITDB_DATABASE=data_warehouse

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_NAME=data-warehouse

# -----------------------------------------------------------------------------
# GraphDB
# -----------------------------------------------------------------------------
GDB_HEAP_SIZE=1g
GDB_MIN_MEM=1g
GDB_MAX_MEM=1g
GDB_MASTER_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Kafka (in-stack bootstrap for containers; external orchestrators use PUBLIC_HOST:9092)
# -----------------------------------------------------------------------------
KAFKA_ADVERTISED_HOST=alfie.iti.gr

# -----------------------------------------------------------------------------
# AutoML services (host or separate stack; used by automl-consumer)
# -----------------------------------------------------------------------------
TABULAR_AUTOML_HOST=host.docker.internal
TABULAR_AUTOML_PORT=8001
VISION_AUTOML_HOST=host.docker.internal
VISION_AUTOML_PORT=8002

# -----------------------------------------------------------------------------
# Optional telemetry / ops
# -----------------------------------------------------------------------------
# LOGFIRE_TOKEN=
# GDPR_DELETE_TOKEN=
