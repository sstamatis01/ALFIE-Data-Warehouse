# AutoDW localized stack — copy to .env before `docker compose up`.
# Defaults target localhost (no alfie.iti.gr). Use docker-compose.deployment.yml
# on the ITI server only; this bundle is for isolated local / partner integration.

# -----------------------------------------------------------------------------
# GitLab image (only the Python app is in the registry; infra uses public images)
# -----------------------------------------------------------------------------
AUTODW_IMAGE=gitlab.catalink.eu:5050/external/alfie_eu/autodw
AUTODW_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Local exposure (host machine and other containers on the host)
# -----------------------------------------------------------------------------
# Kafka PLAINTEXT_HOST listener — must be reachable from your machine / other stacks.
KAFKA_ADVERTISED_HOST=localhost
# Leave empty for direct http://localhost:8000 (no reverse-proxy path prefix)
ROOT_PATH=

# -----------------------------------------------------------------------------
# Host port mappings
# -----------------------------------------------------------------------------
API_PORT=8000
KAFKA_PORT=9092
KAFKA_UI_PORT=8081
MONGO_PORT=27017
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
GRAPHDB_PORT=7200

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_INITDB_DATABASE=data_warehouse

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_NAME=data-warehouse

# -----------------------------------------------------------------------------
# GraphDB
# -----------------------------------------------------------------------------
GDB_HEAP_SIZE=1g
GDB_MIN_MEM=1g
GDB_MAX_MEM=1g
GDB_MASTER_PASSWORD=change-me

# -----------------------------------------------------------------------------
# AutoML (optional — only if you start the automl-consumer profile)
# -----------------------------------------------------------------------------
TABULAR_AUTOML_HOST=host.docker.internal
TABULAR_AUTOML_PORT=8001
VISION_AUTOML_HOST=host.docker.internal
VISION_AUTOML_PORT=8002
