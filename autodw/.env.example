# AutoDW localized stack — copy to .env before `docker compose up`:
#   cp autodw/.env.example autodw/.env
#
# Run from repo root. This bundle targets localhost (not alfie.iti.gr).
# Production ITI server uses docker-compose.deployment.yml at repo root instead.

# -----------------------------------------------------------------------------
# GitLab image (API + Kafka workers only; Mongo/MinIO/Kafka/GraphDB from Docker Hub)
# -----------------------------------------------------------------------------
AUTODW_IMAGE=gitlab.catalink.eu:5050/external/alfie_eu/alfie/autodw
# Tags >= 1.0.3 include ETD-Hub + GraphDB auto-seed in the image. Also published as :latest
AUTODW_VERSION=1.0.3

# -----------------------------------------------------------------------------
# Host exposure (your machine and other stacks on the same host)
# -----------------------------------------------------------------------------
# Kafka PLAINTEXT_HOST — clients outside compose use this in broker metadata
KAFKA_ADVERTISED_HOST=localhost
# Empty = API at http://localhost:8000/docs (no /autodw prefix)
ROOT_PATH=

# -----------------------------------------------------------------------------
# Host port mappings
# -----------------------------------------------------------------------------
API_PORT=8000
KAFKA_PORT=9092
KAFKA_UI_PORT=8081
MONGO_PORT=27017
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
GRAPHDB_PORT=7200

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_INITDB_DATABASE=data_warehouse

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_NAME=data-warehouse

# -----------------------------------------------------------------------------
# ETD-Hub MongoDB seed (API startup when etd_themes is empty)
# Bundled in autodw image >= 1.0.3; compose also mounts ../etd_hub_init for overrides
# -----------------------------------------------------------------------------
ETD_HUB_AUTO_SEED=true
ETD_HUB_SEED_PATH=/app/etd_hub_init/etd_hub_seed.xlsx

# -----------------------------------------------------------------------------
# GraphDB — triple-store backup (container) + API config (Mongo, API startup)
# Requires graphdb_backup_*.tar.gz in repo graphdb_init/ (not in registry image)
# -----------------------------------------------------------------------------
GDB_HEAP_SIZE=1g
GDB_MIN_MEM=1g
GDB_MAX_MEM=1g
GDB_MASTER_PASSWORD=change-me
GRAPHDB_AUTO_SEED=true
GRAPHDB_REPOSITORY=etd-hub-kg-test
GRAPHDB_REST_URL=http://graphdb:7200
GRAPHDB_INTERNAL_HOST=graphdb
GRAPHDB_PORT=7200
GDB_USER=admin
# GDB_PASS is set from GDB_MASTER_PASSWORD in docker-compose.yaml for the API container
GRAPHDB_CONFIG_CREATED_BY=autodw
# GRAPHDB_CONFIG_NAME=AutoDW GraphDB (Docker)

# -----------------------------------------------------------------------------
# AutoML (automl-consumer service; needs tabular/vision on host ports 8001/8002)
# -----------------------------------------------------------------------------
TABULAR_AUTOML_HOST=host.docker.internal
TABULAR_AUTOML_PORT=8001
VISION_AUTOML_HOST=host.docker.internal
VISION_AUTOML_PORT=8002
